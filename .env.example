# Shared local development settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algo_trading
POSTGRES_USER=algo
POSTGRES_PASSWORD=algo
DATABASE_URL=postgresql://algo:algo@localhost:5432/algo_trading

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false

API_HOST=0.0.0.0
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# FYERS market-data integration.
# FYERS_APP_ID and FYERS_SECRET_ID come from the FYERS API dashboard.
# FYERS_ACCESS_TOKEN is generated from the login auth_code flow.
# FYERS_ACCESS_TOKEN is short-lived and may need daily regeneration during review.
FYERS_APP_ID=
FYERS_SECRET_ID=
FYERS_ACCESS_TOKEN=
FYERS_REDIRECT_URI=http://127.0.0.1:8000/fyers/callback

# OpenRouter model routing. One key is used for all selected free models.
# Shared hackathon/reviewer keys should be temporary free-tier keys and may hit rate limits.
LLM_MODE=auto
LLM_TIMEOUT_SECONDS=60
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=AI Trading Platform
OPENROUTER_QWEN_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_STRATEGY_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1-0528:free
OPENROUTER_GLM_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_REPORT_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=openrouter/free

# Direct provider fallbacks used when OpenRouter free limits are exhausted.
# Keep these on free-tier/API-trial model IDs unless you intentionally upgrade.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_INTENT_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_STRATEGY_MODEL=qwen/qwen3-32b
GROQ_RISK_MODEL=qwen/qwen3-32b
GROQ_REASONING_MODEL=openai/gpt-oss-120b
GROQ_REPORT_MODEL=qwen/qwen3-32b

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_INTENT_MODEL=ministral-8b-latest
MISTRAL_SUMMARY_MODEL=mistral-small-latest
MISTRAL_STRATEGY_MODEL=mistral-small-latest
MISTRAL_RISK_MODEL=magistral-small-latest
MISTRAL_REASONING_MODEL=magistral-small-latest
MISTRAL_REPORT_MODEL=mistral-small-latest

CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_INTENT_MODEL=llama-3.1-8b
CEREBRAS_SUMMARY_MODEL=llama-3.3-70b
CEREBRAS_STRATEGY_MODEL=qwen-3-32b
CEREBRAS_RISK_MODEL=qwen-3-32b
CEREBRAS_REASONING_MODEL=gpt-oss-120b
CEREBRAS_REPORT_MODEL=gpt-oss-120b

# Optional news RSS feed. Use a URL template containing {query}, for example:
# NEWS_RSS_URL=https://news.google.com/rss/search?q={query}&hl=en-IN&gl=IN&ceid=IN:en
NEWS_RSS_URL=
NEWS_TIMEOUT_SECONDS=10
