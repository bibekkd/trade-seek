{
  "name": "algo-trading-project",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs all",
    "dev:all": "node scripts/dev.mjs all",
    "dev:backend": "node scripts/dev.mjs backend",
    "dev:web": "node scripts/dev.mjs web",
    "dev:api": "node scripts/dev.mjs api",
    "dev:worker": "node scripts/dev.mjs worker",
    "migrate:api": "uv run --project apps/api alembic -c apps/api/alembic.ini upgrade head",
    "rollback:api": "uv run --project apps/api alembic -c apps/api/alembic.ini downgrade base",
    "test": "uv run --project apps/api pytest",
    "test:api": "uv run --project apps/api pytest",
    "lint": "bun run --cwd apps/web lint",
    "typecheck": "bun run --cwd apps/web typecheck"
  }
}
